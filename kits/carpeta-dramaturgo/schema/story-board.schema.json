{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeus.scriptorium/schemas/story-board.schema.json",
  "title": "Zeus story-board (CARPETA DRAMATURGO)",
  "description": "Contrato actos→widgets destilado de ALEPH_ET_OMEGA y SOLVE_ET_COAGULA. Acepta dos dialectos históricos vía oneOf; ambos normalizan a acts[].widgets.",
  "oneOf": [
    { "$ref": "#/$defs/dialectSolve" },
    { "$ref": "#/$defs/dialectAleph" }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "widgetId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "actId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^act-[0-9]+$"
    },
    "dialectSolve": {
      "type": "object",
      "additionalProperties": true,
      "required": ["acts"],
      "properties": {
        "version": { "type": ["integer", "string", "number"] },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "generated_at": { "type": "string" },
        "acts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "widgets"],
            "properties": {
              "id": { "$ref": "#/$defs/actId" },
              "title": { "type": "string" },
              "blockchain": { "type": ["integer", "number"] },
              "widgets": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/widgetId" }
              },
              "agentchain": { "type": "string" },
              "status": { "type": "string" },
              "optional": { "type": "boolean" }
            }
          }
        },
        "dual_rails": { "type": "array" },
        "cache_panels": { "type": "object" },
        "uichain_specs": { "type": "string" },
        "ayuda": { "type": "string" }
      }
    },
    "dialectAleph": {
      "type": "object",
      "additionalProperties": true,
      "required": ["acts", "blocks"],
      "properties": {
        "schema_version": { "type": "string" },
        "game": { "$ref": "#/$defs/nonEmptyString" },
        "generated_at": { "type": "string" },
        "source_root": { "type": "string" },
        "tablero_url": { "type": "string" },
        "acts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "blocks"],
            "properties": {
              "id": { "$ref": "#/$defs/actId" },
              "label": { "type": "string" },
              "blocks": {
                "type": "array",
                "minItems": 1,
                "items": { "type": ["integer", "number"] }
              }
            }
          }
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["n", "act", "uichain"],
            "properties": {
              "n": { "type": ["integer", "number"] },
              "act": { "$ref": "#/$defs/actId" },
              "title": { "type": "string" },
              "blockchain": { "type": "object" },
              "tablero": { "type": "object" },
              "uichain": {
                "type": "object",
                "required": ["widgets"],
                "properties": {
                  "present": { "type": "boolean" },
                  "paths": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "widgets": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/widgetId" }
                  }
                }
              },
              "chips": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
