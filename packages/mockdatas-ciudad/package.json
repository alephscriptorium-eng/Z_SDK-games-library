{
  "name": "@zeus/mockdatas-ciudad",
  "version": "0.1.0",
  "description": "City mockdatas pack: DISK_01 firehose pulse + DISK_02/LINEAS city tree for mesh browsers.",
  "type": "module",
  "main": "index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./package.json": "./package.json"
  },
