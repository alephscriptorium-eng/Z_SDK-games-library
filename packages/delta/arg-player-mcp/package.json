        "packages/delta/spec/CASOS.md",
        "packages/delta/spec/CONTRATO.md"
      ]
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zeus/arg-domain": "^0.1.0",
    "@zeus/playbook-kit": "^0.1.2",
    "@zeus/player-mcp-kit": "^0.1.2",
    "@zeus/presets-sdk": "^0.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@zeus/test-utils": "^0.1.2"
  },
  "private": true
}
