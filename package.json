{
  "name": "z-sdk-games-library",
  "version": "0.0.0",
  "private": true,
  "description": "Z_SDK-games-library — juegos Zeus (delta, pozo, solve-coagula), start packs y CARPETA DRAMATURGO",
  "type": "module",
  "workspaces": [
    "packages/delta/*",
    "packages/pozo",
    "packages/solve-coagula",
    "packages/startpack-*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "setup:zeus-sdk": "node scripts/ensure-zeus-sdk.mjs",
    "preinstall": "node scripts/ensure-zeus-sdk.mjs",
    "test": "npm run test:delta && npm run test:pozo && npm run test:solve-coagula && npm run test:startpack && npm run test:carpeta-dramaturgo",
    "test:delta": "npm test -w @zeus/arg-domain && npm test -w @zeus/arg-feeds && npm test -w @zeus/arg-console && npm test -w @zeus/arg-player-mcp",
    "test:pozo": "npm test -w @zeus/pozo",
    "test:solve-coagula": "npm test -w @zeus/solve-coagula",
    "test:startpack": "npm test -w @zeus/startpack-delta && npm test -w @zeus/startpack-pozo && npm test -w @zeus/startpack-sketch && npm test -w @zeus/startpack-solve-coagula",
    "test:carpeta-dramaturgo": "node kits/carpeta-dramaturgo/test/run.mjs",
    "instantiate:carpeta-dramaturgo": "node kits/carpeta-dramaturgo/scripts/instantiate.mjs",
    "test:arg-domain": "npm test -w @zeus/arg-domain",
    "demo:arg": "npm run demo -w @zeus/arg-demos",
    "demo:pozo": "npm run demo -w @zeus/pozo",
    "demo:solve-coagula": "npm run demo -w @zeus/solve-coagula",
    "e2e:arg": "node e2e/arg-demo.mjs",
    "e2e:pozo-mcp": "node e2e/pozo-mcp-demo.mjs",
    "e2e:solve-coagula-mcp": "node e2e/solve-coagula-mcp-demo.mjs",
    "e2e:arg-mcp": "node e2e/arg-mcp-demo.mjs",
    "e2e:arg-feeds": "node e2e/arg-feeds-demo.mjs",
    "e2e:arg-horse": "node e2e/arg-horse-demo.mjs",
    "e2e:arg-track": "node e2e/arg-track-demo.mjs",
    "e2e:playbook-kit": "node e2e/playbook-kit-demo.mjs",
    "e2e:startpack": "node e2e/startpack-round.mjs",
    "release:startpack": "node scripts/notario-release.mjs",
    "build:zeus-overrides": "node scripts/build-zeus-overrides.mjs"
  },
  "license": "AIPLv1",
  "dependencies": {
    "@zeus/app-shell": "file:.deps/zeus-sdk/packages/engine/app-shell",
    "@zeus/authority-kit": "file:.deps/zeus-sdk/packages/engine/authority-kit",
    "@zeus/feed-kit": "file:.deps/zeus-sdk/packages/engine/feed-kit",
    "@zeus/firehose-core": "file:.deps/zeus-sdk/packages/engine/firehose-core",
    "@zeus/game-engine": "file:.deps/zeus-sdk/packages/engine/game-engine",
    "@zeus/http-contract": "file:.deps/zeus-sdk/packages/engine/http-contract",
    "@zeus/linea-kit": "file:.deps/zeus-sdk/packages/engine/linea-kit",
    "@zeus/playbook-kit": "file:.deps/zeus-sdk/packages/engine/playbook-kit",
    "@zeus/player-mcp-kit": "file:.deps/zeus-sdk/packages/engine/player-mcp-kit",
    "@zeus/presets-sdk": "file:.deps/zeus-sdk/packages/engine/presets-sdk",
    "@zeus/protocol": "file:.deps/zeus-sdk/packages/engine/protocol",
    "@zeus/room-client-browser": "file:.deps/zeus-sdk/packages/engine/room-client-browser",
    "@zeus/rooms": "file:.deps/zeus-sdk/packages/engine/rooms",
    "@zeus/test-utils": "file:.deps/zeus-sdk/packages/engine/test-utils",
    "@zeus/ui-3d-kit": "file:.deps/zeus-sdk/packages/engine/ui-3d-kit",
    "@zeus/ui-kit": "file:.deps/zeus-sdk/packages/engine/ui-kit",
    "@zeus/view-kit": "file:.deps/zeus-sdk/packages/engine/view-kit",
    "@zeus/volumes-ops": "file:.deps/zeus-sdk/packages/engine/volumes-ops",
    "@zeus/webrtc-signaling": "file:.deps/zeus-sdk/packages/engine/webrtc-signaling",
    "@zeus/3d-monitor": "file:.deps/zeus-sdk/packages/mesh/3d-monitor",
    "@zeus/blob-sync-harness": "file:.deps/zeus-sdk/packages/mesh/blob-sync-harness",
    "@zeus/blobstore-client": "file:.deps/zeus-sdk/packages/mesh/blobstore-client",
    "@zeus/cache-browser": "file:.deps/zeus-sdk/packages/mesh/cache-browser",
    "@zeus/console-monitor": "file:.deps/zeus-sdk/packages/mesh/console-monitor",
    "@zeus/firehose-browser": "file:.deps/zeus-sdk/packages/mesh/firehose-browser",
    "@zeus/force-system": "file:.deps/zeus-sdk/packages/mesh/force-system",
    "@zeus/linea-firehose": "file:.deps/zeus-sdk/packages/mesh/linea-firehose",
    "@zeus/linea-system": "file:.deps/zeus-sdk/packages/mesh/linea-system",
    "@zeus/oasis-webrtc": "file:.deps/zeus-sdk/packages/mesh/oasis-webrtc",
    "@zeus/operator-bridge": "file:.deps/zeus-sdk/packages/mesh/operator-bridge",
    "@zeus/player-3d-ui": "file:.deps/zeus-sdk/packages/mesh/player-3d-ui",
    "@zeus/player-ui": "file:.deps/zeus-sdk/packages/mesh/player-ui",
    "@zeus/socket-server": "file:.deps/zeus-sdk/packages/mesh/socket-server",
    "@zeus/solar-system": "file:.deps/zeus-sdk/packages/mesh/solar-system",
    "@zeus/ssb-system": "file:.deps/zeus-sdk/packages/mesh/ssb-system",
    "@zeus/webrtc-viewer": "file:.deps/zeus-sdk/packages/mesh/webrtc-viewer",
    "@zeus/editor-ui": "file:.deps/zeus-sdk/packages/editor/editor-ui"
  }
}
